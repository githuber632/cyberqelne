# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/cyberqeln?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-64-chars"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-in-production"

# App
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# AWS S3 (file storage)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=cyberqeln-media

# Payment gateways (mock keys for dev)
PAYME_MERCHANT_ID=your-merchant-id
PAYME_SECRET_KEY=your-secret-key
CLICK_SERVICE_ID=your-service-id
CLICK_MERCHANT_ID=your-merchant-id
UZCARD_API_KEY=your-api-key
HUMO_API_KEY=your-api-key

# Redis (for WebSocket scaling, optional)
REDIS_URL=redis://localhost:6379
